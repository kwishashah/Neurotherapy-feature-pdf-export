<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" name="NeurotherapyDashboard">

    <Properties>
        <!-- ${sys:user.home} expands to the user's home directory at runtime. -->
        <Property name="LOG_DIR">${sys:user.home}/.neuro/logs</Property>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %logger{36} - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Console: human-readable -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- Rolling file: ~/.neuro/logs/neurotherapy.log, rotated at 10 MB, 7 archives kept -->
        <RollingFile name="RollingFile"
                     fileName="${LOG_DIR}/neurotherapy.log"
                     filePattern="${LOG_DIR}/neurotherapy-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application code: verbose -->
        <Logger name="com.neuro" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- Noisy third-party libraries: keep at WARN -->
        <Logger name="com.mysql" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>
        <Logger name="org.apache.pdfbox" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>

</Configuration>
